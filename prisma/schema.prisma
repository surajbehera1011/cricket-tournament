generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  ADMIN
  CAPTAIN
  MASTER
}

enum TeamStatus {
  PENDING_APPROVAL
  INCOMPLETE
  COMPLETE
  READY
}

enum RegistrationType {
  TEAM
  INDIVIDUAL
}

enum PoolStatus {
  PENDING_APPROVAL
  LOOKING_FOR_TEAM
  ASSIGNED
  NONE
}

enum RegistrationSource {
  APP_FORM
}

enum MembershipType {
  TEAM_SUBMISSION
  DRAFT_PICK
}

enum AuditAction {
  CREATE_TEAM
  REGISTER_TEAM
  REGISTER_INDIVIDUAL
  ASSIGN_PLAYER
  REMOVE_PLAYER
  MARK_COMPLETE
  MARK_INCOMPLETE
  UPDATE_SETTINGS
  APPROVE_TEAM
  REJECT_TEAM
  APPROVE_INDIVIDUAL
  REJECT_INDIVIDUAL
  CREATE_CAPTAIN
  UPDATE_CAPTAIN
  RECORD_SCORE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PickleballCategory {
  MENS_SINGLES
  WOMENS_SINGLES
  MENS_DOUBLES
  WOMENS_DOUBLES
  MIXED_DOUBLES
}

enum PickleballStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum FixtureSport {
  CRICKET
  PICKLEBALL
}

enum FixtureStatus {
  DRAFT
  FROZEN
}

enum FixtureStage {
  GROUP
  KNOCKOUT
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
}

// ─── Models ─────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String   @default("")
  displayName String
  role        UserRole @default(CAPTAIN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  captainOfTeams Team[]     @relation("TeamCaptain")
  auditLogs      AuditLog[]

  @@map("users")
}

model Team {
  id            String     @id @default(uuid())
  name          String     @unique
  captainName   String     @default("")
  color         String     @default("")
  captainUserId String?
  captain       User?      @relation("TeamCaptain", fields: [captainUserId], references: [id])
  teamSize      Int        @default(10)
  status        TeamStatus @default(PENDING_APPROVAL)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  memberships TeamMembership[]

  @@map("teams")
}

model Player {
  id              String     @id @default(uuid())
  fullName        String
  email           String?
  gender          Gender     @default(MALE)
  preferredRole   String     @default("")
  experienceLevel String     @default("")
  comments        String?
  poolStatus      PoolStatus @default(NONE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  memberships TeamMembership[]

  @@map("players")
}

model Registration {
  id                String             @id @default(uuid())
  registrationType  RegistrationType
  submitterEmail    String
  submitterName     String
  submittedAt       DateTime           @default(now())
  teamName          String?
  captainName       String?
  teamSize          Int?
  teamPlayersJson   Json?
  preferredRole     String?
  experienceLevel   String?
  comments          String?
  poolStatus        PoolStatus         @default(NONE)
  source            RegistrationSource @default(APP_FORM)
  createdAt         DateTime           @default(now())

  @@map("registrations")
}

model TeamMembership {
  id             String         @id @default(uuid())
  teamId         String
  team           Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId       String
  player         Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  membershipType MembershipType
  positionSlot   String?
  createdAt      DateTime       @default(now())

  @@unique([teamId, playerId])
  @@map("team_memberships")
}

model AuditLog {
  id          String      @id @default(uuid())
  actorUserId String
  actor       User        @relation(fields: [actorUserId], references: [id])
  action      AuditAction
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

model TournamentSettings {
  id                       String   @id @default("singleton")
  maxTeamSize              Int      @default(10)
  mandatoryPlayerCount     Int      @default(8)
  mandatoryFemaleCount     Int      @default(1)
  extraPlayerLimit         Int      @default(2)
  minFemalePerTeam         Int      @default(1)
  tournamentName           String   @default("Office Cricket Tournament")
  registrationOpen         Boolean  @default(true)
  tournamentStartDate      DateTime?
  cricketStartDate         DateTime?
  pickleballStartDate      DateTime?
  cricketRegCloseDate      DateTime?
  pickleballRegCloseDate   DateTime?
  cricketVenue             String   @default("")
  cricketVenueMapUrl       String   @default("")
  pickleballVenue          String   @default("")
  pickleballVenueMapUrl    String   @default("")
  targetCricketTeams       Int      @default(12)
  cricketGroupCount        Int      @default(4)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("tournament_settings")
}

model PickleballRegistration {
  id            String             @id @default(uuid())
  category      PickleballCategory
  player1Name   String
  player1Email  String
  player2Name   String?
  player2Email  String?
  status        PickleballStatus   @default(PENDING_APPROVAL)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("pickleball_registrations")
}

model Fixture {
  id         String        @id @default(uuid())
  sport      FixtureSport
  status     FixtureStatus @default(DRAFT)
  groupCount Int           @default(4)
  frozenAt   DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  matches Match[]

  @@unique([sport])
  @@map("fixtures")
}

model Match {
  id               String       @id @default(uuid())
  fixtureId        String
  fixture          Fixture      @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  sport            FixtureSport
  stage            FixtureStage
  groupName        String?
  roundNumber      Int
  matchNumber      Int
  category         String?
  team1Id          String?
  team2Id          String?
  entry1Id         String?
  entry2Id         String?
  score1           String?
  score2           String?
  winnerId         String?
  scheduledDate    DateTime?
  venue            String?
  status           MatchStatus  @default(SCHEDULED)
  notificationSent Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("matches")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}
