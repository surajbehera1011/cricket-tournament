# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://cricket:cricket_dev@localhost:5432/cricket_tournament

# ─── NextAuth ────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-32-char-string

# ─── Microsoft Entra ID (Azure AD) ──────────────────────
# Leave blank to use dev login only
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ─── Dev Mode ────────────────────────────────────────────
# Set to "true" to enable credential-based dev login in production
ENABLE_DEV_LOGIN=false
