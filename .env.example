# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://cricket:cricket_dev@localhost:5432/cricket_tournament

# ─── NextAuth ────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-32-char-string

# ─── SMTP (for email notifications) ──────────────────────
# For Office 365 / Outlook: host=smtp.office365.com port=587
# For Gmail: host=smtp.gmail.com port=587
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_EMAIL=your-service-account@company.com
SMTP_PASSWORD=your-password
SMTP_FROM_NAME=Align Sports League
APP_URL=http://localhost:3000
